# PALACE runtime config
# Web dev is standardized on localhost:3000.
NEXT_PUBLIC_WEB_ORIGIN=http://localhost:3000

# wsigomi API
NEXT_PUBLIC_API_URL=https://api.wsig.me

# Use NEXT_PUBLIC_API_TOKEN for browser-side requests.
# API_TOKEN is still read by server-side code and route handlers.
NEXT_PUBLIC_API_TOKEN=your-api-token-here
API_TOKEN=your-api-token-here

# Marlin voice API
NEXT_PUBLIC_MARLIN_URL=https://marlin.sigflix.stream
